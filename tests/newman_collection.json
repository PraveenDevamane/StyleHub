{
  "info": {
    "name": "StyleHub Public Services Verification",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Retrieve Products from Firestore",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "https://firestore.googleapis.com/v1/projects/{{EXPO_PUBLIC_FIREBASE_PROJECT_ID}}/databases/(default)/documents/products?pageSize=3",
          "protocol": "https",
          "host": [
            "firestore",
            "googleapis",
            "com"
          ],
          "path": [
            "v1",
            "projects",
            "{{EXPO_PUBLIC_FIREBASE_PROJECT_ID}}",
            "databases",
            "(default)",
            "documents",
            "products"
          ],
          "query": [
            {
              "key": "pageSize",
              "value": "3"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Firestore products retrieval should be successful\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const response = pm.response.json();",
              "let imageUrl = null;",
              "",
              "if (response.documents && response.documents.length > 0) {",
              "    for (const doc of response.documents) {",
              "        const fields = doc.fields || {};",
              "        ",
              "        // 1. Try to extract from product_images array",
              "        if (fields.product_images && fields.product_images.arrayValue && fields.product_images.arrayValue.values) {",
              "            const firstImg = fields.product_images.arrayValue.values[0];",
              "            if (firstImg && firstImg.mapValue && firstImg.mapValue.fields && firstImg.mapValue.fields.image_url) {",
              "                imageUrl = firstImg.mapValue.fields.image_url.stringValue;",
              "                if (imageUrl) break;",
              "            }",
              "        }",
              "        ",
              "        // 2. Try to extract from image_urls array",
              "        if (fields.image_urls && fields.image_urls.arrayValue && fields.image_urls.arrayValue.values) {",
              "            const firstUrl = fields.image_urls.arrayValue.values[0];",
              "            if (firstUrl && firstUrl.stringValue) {",
              "                imageUrl = firstUrl.stringValue;",
              "                break;",
              "            }",
              "        }",
              "    }",
              "}",
              "",
              "// Fallback if no images are currently in the database",
              "if (!imageUrl) {",
              "    imageUrl = \"https://images.unsplash.com/photo-1521572267360-ee0c2909d518?w=500\";",
              "}",
              "",
              "pm.collectionVariables.set(\"TEST_IMAGE_URL\", imageUrl);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Verify Image Retrieval",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{TEST_IMAGE_URL}}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Product image should retrieve successfully with 200 OK\", function () {",
              "    pm.response.to.have.status(200);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "TEST_IMAGE_URL",
      "value": ""
    }
  ]
}
